# Database (use port 5433 to avoid conflict with local postgres)
DATABASE_URL=postgresql+asyncpg://triage:triage@localhost:5433/medical_triage
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=medical_triage

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=15

# Application
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

